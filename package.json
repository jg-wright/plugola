{
  "name": "@plugola/mono-repo",
  "private": true,
  "version": "0.0.0",
  "description": "The MOL Ads mono-repo",
  "main": "index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean && rm -rf packages/*/dist",
    "prepare": "husky",
    "start": "tsc --build --watch"
  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/johngeorgewright/ts-mono-repo/issues"
  },
  "homepage": "https://github.com/johngeorgewright/ts-mono-repo#readme",
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "25.9.2",
    "@vitest/runner": "4.1.8",
    "ci-info": "4.4.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "17.0.7",
    "mkdirp-infer-owner": "2.0.0",
    "nx": "22.7.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{md,json,js,jsx,ts,tsx,yml,yaml}": [
      "yarn prettier --write"
    ]
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "packageManager": "yarn@4.16.0",
  "resolutions": {
    "@johngw/stream-common": "file:///Users/john.wright/Workspace/stream/packages/stream-common"
  }
}
